<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Decompiled</title>
  <meta name="description" content="Deep dives into codebases, research papers, and the fundamentals behind them." />

  <meta property="og:title" content="Decompiled" />
  <meta property="og:description" content="Understanding systems by taking them apart." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://decompiled-blog.github.io/" />
  <meta property="og:image" content="https://decompiled-blog.github.io/og-image.png" />

  <link href="https://fonts.googleapis.com/css2?family=Space+Mono&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:     #0b1b2b;
      --text:   #e5e7eb;
      --muted:  #9ca3af;
      --accent: #3b82f6;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding-top: 2rem;
      padding-bottom: 2rem;
      padding-left: max(1rem, env(safe-area-inset-left));
      padding-right: max(1rem, env(safe-area-inset-right));
    }

    .container {
      width: 100%;
      max-width: 680px;
      padding-inline: 0.5rem;
    }

    @media (max-width: 640px) {
      body {
        padding-left: max(1.5rem, env(safe-area-inset-left));
        padding-right: max(1.5rem, env(safe-area-inset-right));
      }

      .container {
        padding-inline: 1rem;
      }
    }

    .logo {
      font-family: 'Space Mono', monospace;
      font-size: 1.2rem;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    h1 {
      font-family: 'Space Mono', monospace;
      font-size: clamp(1.4rem, 4vw, 2rem);
      line-height: 1.3;
      margin: 0 0 1rem;
    }

    .tagline {
      font-size: 1.1rem;
      margin-bottom: 2rem;
    }

    .status {
      font-family: 'Space Mono', monospace;
      color: var(--muted);
      margin-bottom: 0rem;
    }

    /* ── Allocator ── */
    .alloc-wrap {
      margin-bottom: 2rem;
    }

    .alloc-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .alloc-title {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      color: var(--muted);
    }

    .alloc-legend {
      display: flex;
      gap: 0.85rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      color: var(--muted);
    }

    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 1px;
      flex-shrink: 0;
    }

    /*
      Key fix: the wrapper is block-level and constrained to the container.
      The canvas is set via JS to exactly match the wrapper's clientWidth —
      never wider, so it can't overflow on mobile.
    */
    .alloc-canvas-wrap {
      width: 100%;
      display: block;
      border: 1px solid #1e3a5a;
      border-radius: 3px;
      background: #0d2340;
      overflow: hidden; /* belt-and-suspenders */
    }

    #allocCanvas {
      display: block;
      /* JS sets width/height attributes and style */
    }

    .alloc-stats {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }

    .stat__label {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .stat__val {
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
      color: var(--text);
    }

    .alloc-ticker {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      margin-top: 0.5rem;
      height: 1.2em;
      overflow: hidden;
    }

    .alloc-ticker span {
      display: inline-block;
      animation: tick-in 0.2s ease;
    }

    :global(.tick-malloc) { color: #60a5fa; }
    :global(.tick-free)   { color: #f59e0b; }
    :global(.tick-info)   { color: var(--muted); }

    @keyframes tick-in {
      from { opacity: 0; transform: translateY(4px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Footer ── */
    .footer {
      margin-top: 1.5rem;
      margin-bottom: 1.5rem;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .line {
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
      border: none;
      background: none;
    }
  </style>
</head>

<body>
  <div class="container">

    <div class="logo">// Decompiled</div>

    <h1>Understanding systems by taking them apart.</h1>

    <div class="tagline">
      Deep dives into codebases, research papers, and the fundamentals behind them.
    </div>
    
    <div class="status">
      status: building  
    </div>
    
    <!-- <div class="footer">coming soon.</div> -->

    <hr class="line">
    
    <div class="alloc-wrap">

      <div class="alloc-header">
        <span class="alloc-title">// heap — live allocator</span>
        <div class="alloc-legend">
          <div class="legend-item">
            <div class="legend-dot" style="background:#3b82f6"></div>
            allocated
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#6b7280"></div>
            header
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:#162b42"></div>
            free
          </div>
        </div>
      </div>

      <div class="alloc-canvas-wrap" id="allocWrap">
        <canvas id="allocCanvas"></canvas>
      </div>

      <div class="alloc-stats">
        <div>
          <div class="stat__label">used</div>
          <div class="stat__val" id="statUsed">0 B</div>
        </div>
        <div>
          <div class="stat__label">free</div>
          <div class="stat__val" id="statFree">0 B</div>
        </div>
        <div>
          <div class="stat__label">fragments</div>
          <div class="stat__val" id="statFrags">0</div>
        </div>
        <div>
          <div class="stat__label">allocs</div>
          <div class="stat__val" id="statAllocs">0</div>
        </div>
        <div>
          <div class="stat__label">frees</div>
          <div class="stat__val" id="statFrees">0</div>
        </div>
      </div>

      <div class="alloc-ticker" id="allocTicker"><span>&nbsp;</span></div>

    </div>


  </div>
</body>

<script>
(function () {

  const HEAP  = 256;
  const HDR   = 2;
  const MIN   = 4;
  const MAX   = 36;
  const TICK  = 1200;

  const COLORS = [
    '#3b82f6','#60a5fa','#93c5fd',
    '#2563eb','#7dd3fc','#38bdf8',
    '#1d4ed8','#0ea5e9',
  ];

  let cells        = [];
  let blocks       = [];
  let blockCounter = 0;
  let colorIdx     = 0;
  let totalAllocs  = 0;
  let totalFrees   = 0;
  let phase        = 'filling';
  let phaseTimer   = 0;

  function initHeap() {
    cells        = Array.from({ length: HEAP }, () => ({ type: 'free', color: null }));
    blocks       = [];
    blockCounter = 0;
    colorIdx     = 0;
    totalAllocs  = 0;
    totalFrees   = 0;
  }

  function firstFit(size) {
    const need = size + HDR;
    let run = 0, start = -1;
    for (let i = 0; i < HEAP; i++) {
      if (cells[i].type === 'free') {
        if (run === 0) start = i;
        if (++run >= need) return start;
      } else { run = 0; start = -1; }
    }
    return -1;
  }

  function malloc(size) {
    const start = firstFit(size);
    if (start < 0) return null;
    const id    = blockCounter++;
    const color = COLORS[colorIdx++ % COLORS.length];
    for (let i = start; i < start + HDR; i++)
      cells[i] = { type: 'header', color: '#6b7280', blockId: id };
    for (let i = start + HDR; i < start + HDR + size; i++)
      cells[i] = { type: 'data', color, blockId: id };
    const b = { id, start, size, color, freed: false };
    blocks.push(b);
    totalAllocs++;
    return b;
  }

  function freeFn(block) {
    if (block.freed) return;
    block.freed = true;
    totalFrees++;
    for (let i = block.start; i < block.start + HDR + block.size; i++)
      cells[i] = { type: 'free', color: null };
    blocks = blocks.filter(b => b.id !== block.id);
  }

  function getStats() {
    let used = 0, free = 0, frags = 0;
    let inFree = false;
    cells.forEach(c => {
      if (c.type === 'free') { free++; if (!inFree) { frags++; inFree = true; } }
      else { used++; inFree = false; }
    });
    return { used, free, frags };
  }

  // ── Canvas setup ──
  const wrap   = document.getElementById('allocWrap');
  const canvas = document.getElementById('allocCanvas');
  const ctx    = canvas.getContext('2d');
  const DPR    = Math.min(window.devicePixelRatio || 1, 2);

  let COLS = 32, PX = 8;
  let flashes = [];

  function flash(startIdx, len) {
    const set = new Set();
    for (let i = startIdx; i < Math.min(startIdx + HDR + len, HEAP); i++) set.add(i);
    const f = { set, alpha: 0.65 };
    flashes.push(f);
    function fade() {
      f.alpha -= 0.05;
      if (f.alpha <= 0) { flashes = flashes.filter(x => x !== f); return; }
      requestAnimationFrame(fade);
    }
    requestAnimationFrame(fade);
  }

  function layout() {
    // Use clientWidth — this is the inner width after border, safe on mobile
    const W = wrap.clientWidth;
    if (!W) return;

    // Choose cell pixel size: target ~8px, clamp 5–10
    PX   = Math.max(5, Math.min(10, Math.floor(W / 32)));
    COLS = Math.floor(W / PX);
    const ROWS = Math.ceil(HEAP / COLS);
    const H    = ROWS * PX;

    // CSS size — never wider than the wrapper
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';

    // Backing-store size (HiDPI)
    canvas.width  = Math.round(W * DPR);
    canvas.height = Math.round(H * DPR);

    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(DPR, DPR);
  }

  function draw() {
    const W = canvas.clientWidth;
    const H = canvas.clientHeight;
    if (!W || !COLS) return;

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0d2340';
    ctx.fillRect(0, 0, W, H);

    const gap = PX >= 7 ? 1 : 0;
    const sz  = PX - gap;

    for (let i = 0; i < HEAP; i++) {
      const col = i % COLS;
      const row = Math.floor(i / COLS);
      const x   = col * PX + gap;
      const y   = row * PX + gap;
      const c   = cells[i];
      ctx.fillStyle =
        c.type === 'free'   ? '#162b42' :
        c.type === 'header' ? '#6b7280' :
        c.color;
      ctx.fillRect(x, y, sz, sz);
    }

    flashes.forEach(f => {
      if (f.alpha <= 0) return;
      ctx.fillStyle = `rgba(255,255,255,${f.alpha * 0.4})`;
      f.set.forEach(i => {
        const col = i % COLS, row = Math.floor(i / COLS);
        ctx.fillRect(col * PX + gap, row * PX + gap, sz, sz);
      });
    });
  }

  function renderLoop() { draw(); requestAnimationFrame(renderLoop); }

  function setTicker(msg, kind = 'info') {
    const cls =
      kind === 'malloc' ? 'tick-malloc' :
      kind === 'free'   ? 'tick-free'   :
                          'tick-info';
    document.getElementById('allocTicker').innerHTML = `<span class="${cls}">${msg}</span>`;
  }

  function updateStats() {
    const s = getStats();
    document.getElementById('statUsed').textContent   = s.used  + ' B';
    document.getElementById('statFree').textContent   = s.free  + ' B';
    document.getElementById('statFrags').textContent  = s.frags;
    document.getElementById('statAllocs').textContent = totalAllocs;
    document.getElementById('statFrees').textContent  = totalFrees;
  }

  function tick() {
    phaseTimer++;

    if (phase === 'filling') {
      const size = Math.floor(Math.random() * (MAX - MIN) + MIN);
      const b = malloc(size);
      if (b) {
        flash(b.start, b.size);
        setTicker(`malloc(${size})  →  0x${b.start.toString(16).padStart(3,'0')}`, 'malloc');
      } else {
        phase = 'fragmenting'; phaseTimer = 0;
        setTicker('heap full — freeing blocks', 'info');
      }
      if (phaseTimer >= 12) { phase = 'fragmenting'; phaseTimer = 0; }

    } else if (phase === 'fragmenting') {
      const live = blocks.filter(b => !b.freed);
      if (!live.length) { phase = 'compacting'; phaseTimer = 0; return; }
      const b = live[Math.floor(Math.random() * live.length)];
      const addr = b.start;
      freeFn(b);
      flash(addr, b.size);
      setTicker(`free(0x${addr.toString(16).padStart(3,'0')})  →  ${b.size} B reclaimed`, 'free');
      if (phaseTimer >= 9) { phase = 'compacting'; phaseTimer = 0; }

    } else {
      const live = blocks.filter(b => !b.freed);
      if (live.length) {
        const b = live[0];
        const addr = b.start;
        freeFn(b);
        flash(addr, b.size);
        setTicker(`free(0x${addr.toString(16).padStart(3,'0')})  →  coalescing`, 'free');
      } else {
        initHeap();
        phase = 'filling'; phaseTimer = 0;
        setTicker('heap reset — new cycle', 'info');
      }
    }

    updateStats();
  }

  // ── Boot ──
  initHeap();

  // Wait one frame so the DOM has rendered and clientWidth is accurate
  requestAnimationFrame(() => {
    layout();
    updateStats();
    renderLoop();
    setTimeout(() => setInterval(tick, TICK), 800);
  });

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(layout, 80);
  });

})();
</script>
</html>